      "name": "Generate Social Posts"
    },
    {
      "parameters": {
        "jsCode": "// Get the AI output from the previous node\nconst output = $input.first().json.text;\n\n// Extract LinkedIn section\nconst linkedinMatch = output.match(/LinkedIn:\\s*([\\s\\S]*?)Twitter:/i);\n\n// Extract Twitter section\nconst twitterMatch = output.match(/Twitter:\\s*([\\s\\S]*)/i);\n\nreturn [{\n  json: {\n    linkedin: linkedinMatch ? linkedinMatch[1].trim() : \"\",\n    twitter: twitterMatch ? twitterMatch[1].trim() : \"\",\n    generatedAt: new Date().toISOString()\n  }\n}];"
